{
  "version": 2,
  "buildCommand": "echo 'Static build complete'",
  "public": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path*",
      "destination": "/:path*/"
    },
    {
      "source": "/www/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/menu",
      "destination": "/menu.html"
    },
    {
      "source": "/deals",
      "destination": "/deals.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
